{
  "name": "brainstorming-bot",
  "version": "1.0.0",
  "description": "Discord brainstorming analysis bot with multi-project memory",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "register:commands": "tsx src/discord/registerCommands.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ollama-live": "vitest run tests/ollama.live.test.ts"
  },
  "keywords": [
    "discord",
    "bot",
    "brainstorming",
    "analysis"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
