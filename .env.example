DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: set for instant command updates in one server
DISCORD_GUILD_ID=
ENABLE_MESSAGE_CONTENT_INTENT=false
DATA_FILE=./data/store.json
ANALYZER_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT_MS=180000
# Optional TLS trust override for filtered networks (must point to PEM)
# NODE_EXTRA_CA_CERTS=C:/Users/<you>/.certs/norton-webmail-shield-root.pem
